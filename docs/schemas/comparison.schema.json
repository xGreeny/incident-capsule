{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xGreeny/incident-capsule/v1.3.0/docs/schemas/comparison.schema.json",
  "title": "Incident Capsule capsule comparison report",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "tool",
    "baseline",
    "current",
    "summary",
    "sections"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "enum": ["1.3"] },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "baseline": {
      "type": "object",
      "required": ["path", "capsuleId"],
      "properties": {
        "path": { "type": "string" },
        "capsuleId": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "current": {
      "type": "object",
      "required": ["path", "capsuleId"],
      "properties": {
        "path": { "type": "string" },
        "capsuleId": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["comparableSections", "skippedSections", "totalAdded", "totalRemoved", "totalChanged"],
      "properties": {
        "comparableSections": { "type": "integer", "minimum": 0 },
        "skippedSections": { "type": "integer", "minimum": 0 },
        "totalAdded": { "type": "integer", "minimum": 0 },
        "totalRemoved": { "type": "integer", "minimum": 0 },
        "totalChanged": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "source", "comparable"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "comparable": { "type": "boolean" },
          "reason": { "type": "string" },
          "identityFields": { "type": "array", "items": { "type": "string" } },
          "baselineCount": { "type": "integer", "minimum": 0 },
          "currentCount": { "type": "integer", "minimum": 0 },
          "addedCount": { "type": "integer", "minimum": 0 },
          "removedCount": { "type": "integer", "minimum": 0 },
          "changedCount": { "type": "integer", "minimum": 0 },
          "added": { "type": "array" },
          "removed": { "type": "array" },
          "changed": { "type": "array" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
