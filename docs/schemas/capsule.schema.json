{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xGreeny/incident-capsule/v1.0.0/docs/schemas/capsule.schema.json",
  "title": "Incident Capsule metadata",
  "type": "object",
  "required": [
    "schemaVersion",
    "tool",
    "capsule",
    "host",
    "collection",
    "configuration",
    "collectors",
    "integrity"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "tool": {
      "type": "object"
    },
    "capsule": {
      "type": "object"
    },
    "host": {
      "type": "object"
    },
    "collection": {
      "type": "object"
    },
    "configuration": {
      "type": "object"
    },
    "collectors": {
      "type": "array"
    },
    "integrity": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
