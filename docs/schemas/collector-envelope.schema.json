{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xGreeny/incident-capsule/v1.3.0/docs/schemas/collector-envelope.schema.json",
  "title": "Incident Capsule collector envelope",
  "type": "object",
  "required": [
    "schemaVersion",
    "capsuleId",
    "collector",
    "capturedAtUtc",
    "host",
    "data"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "enum": ["1.0", "1.1", "1.2", "1.3"]
    },
    "capsuleId": {
      "type": "string",
      "minLength": 1
    },
    "collector": {
      "type": "string",
      "minLength": 1
    },
    "capturedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "data": {},
    "source": {
      "type": ["string", "null"]
    },
    "availability": {
      "type": "string",
      "enum": ["Available", "Partial", "Unavailable", "NotApplicable"]
    },
    "truncated": {
      "type": "boolean"
    },
    "limitReason": {
      "type": ["string", "null"]
    },
    "recordCount": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
