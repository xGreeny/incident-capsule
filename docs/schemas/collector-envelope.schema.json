{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xGreeny/incident-capsule/v1.0.0/docs/schemas/collector-envelope.schema.json",
  "title": "Incident Capsule collector envelope",
  "type": "object",
  "required": [
    "schemaVersion",
    "capsuleId",
    "collector",
    "capturedAtUtc",
    "host",
    "data"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "capsuleId": {
      "type": "string",
      "minLength": 1
    },
    "collector": {
      "type": "string",
      "minLength": 1
    },
    "capturedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "data": {}
  },
  "additionalProperties": false
}
